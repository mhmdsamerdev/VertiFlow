# VertiFlow Configuration
APP_NAME=VertiFlow
DEBUG=true

# Database Configuration (Supabase / PostgreSQL)
# For local Supabase development, use:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:54322/postgres

# For Supabase Cloud, use your connection string from Project Settings > Database
# Example: postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:5432/postgres
# DATABASE_URL=postgresql+asyncpg://postgres:password@db.example.supabase.co:5432/postgres

# Supabase API Keys (Optional - for future expansion)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
